{
  "version": 1,
  "always": [
    {
      "path": "rules/00-dev-flow.md",
      "reason": "全局研发流程"
    },
    {
      "path": "rules/01-delivery-contract.md",
      "reason": "交付契约与设计说明规则"
    }
  ],
  "rules": {
    "agent.pm": {
      "path": "agents/01-pm-agent.md",
      "reason": "需求与 PRD 角色"
    },
    "agent.techLead": {
      "path": "agents/02-tech-lead-agent.md",
      "reason": "架构、边界、接口与数据设计角色"
    },
    "agent.dev": {
      "path": "agents/03-dev-agent.md",
      "reason": "开发与自测角色"
    },
    "agent.qa": {
      "path": "agents/04-qa-agent.md",
      "reason": "测试与验收角色"
    },
    "agent.pmo": {
      "path": "agents/05-pmo-agent.md",
      "reason": "规范治理角色"
    },
    "process.deliveryContract": {
      "path": "rules/01-delivery-contract.md",
      "reason": "交付契约与设计说明规则"
    },
    "process.devEnvironment": {
      "path": "rules/02-dev-environment.md",
      "reason": "开发环境与本地启动规范"
    },
    "backend.code": {
      "path": "rules/backend/01-code.md",
      "reason": "后端代码规范"
    },
    "backend.naming": {
      "path": "rules/backend/02-naming.md",
      "reason": "后端命名规范"
    },
    "backend.api": {
      "path": "rules/backend/03-api.md",
      "reason": "后端 API 规范"
    },
    "backend.db": {
      "path": "rules/backend/04-db.md",
      "reason": "数据库与 migration 规范"
    },
    "backend.module": {
      "path": "rules/backend/05-module.md",
      "reason": "后端模块分层规范"
    },
    "backend.security": {
      "path": "rules/backend/06-security.md",
      "reason": "后端安全规范"
    },
    "backend.persistence": {
      "path": "rules/backend/07-persistence.md",
      "reason": "事务与持久化规范"
    },
    "backend.test": {
      "path": "rules/backend/08-test.md",
      "reason": "后端测试规范"
    },
    "backend.versioning": {
      "path": "rules/backend/09-versioning.md",
      "reason": "版本化发布规范"
    },
    "backend.devFlow": {
      "path": "rules/backend/10-dev-flow.md",
      "reason": "后端开发流程"
    },
    "frontend.vue": {
      "path": "rules/frontend/01-vue-code.md",
      "reason": "Vue 代码规范"
    },
    "frontend.test": {
      "path": "rules/frontend/04-test.md",
      "reason": "前端测试规范"
    },
    "frontend.devFlow": {
      "path": "rules/frontend/05-dev-flow.md",
      "reason": "前端开发流程"
    },
    "frontend.monorepo": {
      "path": "rules/frontend/06-monorepo-architecture.md",
      "reason": "前端 Monorepo 架构规范"
    },
    "product.prd": {
      "path": "rules/product/01-prd-template.md",
      "reason": "PRD 模板规范"
    },
    "product.sprint": {
      "path": "rules/product/02-sprint.md",
      "reason": "Sprint 规范"
    }
  },
  "roles": {
    "pm": ["agent.pm", "product.prd"],
    "tech-lead": ["agent.techLead"],
    "dev": ["agent.dev", "process.devEnvironment"],
    "qa": ["agent.qa"],
    "pmo": ["agent.pmo"]
  },
  "phases": {
    "requirement": ["product.prd"],
    "design": ["agent.techLead"],
    "develop": ["agent.dev", "process.devEnvironment"],
    "verify": ["agent.qa"],
    "release": [],
    "governance": ["agent.pmo"]
  },
  "bundles": {
    "backend": {
      "paths": ["backend/**", "mango/**", "mango-platform/**", "mango-app/**"],
      "keywords": ["后端", "Java", "Spring", "接口", "数据库", "migration", "Flyway", "API"],
      "include": ["backend.devFlow", "backend.code", "backend.naming", "backend.module", "backend.api", "backend.db", "backend.test"]
    },
    "frontend": {
      "paths": ["frontend/**", "mango-ui/**", "apps/**", "packages/**"],
      "keywords": ["前端", "页面", "Vue", "组件", "路由", "E2E", "Playwright", "UI"],
      "include": ["frontend.devFlow", "frontend.vue", "frontend.monorepo", "frontend.test"]
    },
    "pmo": {
      "paths": ["business-pmo/**", "mango-pmo/**", "rules/**", "agents/**"],
      "keywords": ["PMO", "规范治理", "规则治理", "Agent 入口", "Agent入口", "流程规范"],
      "include": ["agent.pmo"]
    },
    "devEnvironment": {
      "paths": ["scripts/**", ".mango/**"],
      "keywords": ["开发环境", "本地环境", "启动", "端口", "工作区", "dev-workspace", "前后端", "数据库名称"],
      "include": ["process.devEnvironment"]
    },
    "product": {
      "paths": ["business-docs/**", "mango-docs/**"],
      "keywords": ["需求", "PRD", "Sprint", "验收标准"],
      "include": ["agent.pm", "product.prd", "product.sprint"]
    },
    "deliveryContract": {
      "paths": ["business-docs/**", "mango-docs/designs/**"],
      "keywords": ["交付契约", "设计文档", "设计说明书", "基于设计", "按设计", "按照设计", "交付台账", "delivery-ledger", "delivery-contract"],
      "include": ["process.deliveryContract"]
    },
    "versioning": {
      "paths": [],
      "keywords": ["版本", "发布", "历史版本", "回滚", "切换版本", "生效版本", "编号规则", "流程定义", "模板"],
      "include": ["backend.versioning", "backend.db", "backend.test"]
    },
    "security": {
      "paths": [],
      "keywords": ["权限", "认证", "授权", "安全", "token", "密码", "密钥"],
      "include": ["backend.security", "backend.api", "backend.test"]
    }
  }
}
