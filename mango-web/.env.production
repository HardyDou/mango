# Mango Web - Production Environment

# API Proxy Path (set by CI/CD or deployment)
VITE_ADMIN_PROXY_PATH=http://127.0.0.1:5555

# Public Path
VITE_PUBLIC_PATH=/

# App
VITE_APP_TITLE=Mango Admin

# SSE/WebSocket Features (disabled by default until backend is ready)
VITE_SSE_ENABLE=false
VITE_WS_ENABLE=false
VITE_USE_MOCK=false
