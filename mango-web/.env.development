# Mango Web - Development Environment

# API Proxy Target (only 127.0.0.1 and localhost allowed for SSRF protection)
VITE_ADMIN_PROXY_PATH=http://127.0.0.1:5555

# Server
VITE_PORT=7777
VITE_OPEN=true

# App
VITE_APP_TITLE=Mango Admin

# SSE/WebSocket Features (disabled by default until backend is ready)
VITE_SSE_ENABLE=false
VITE_WS_ENABLE=false

# Mock API - 前端独立开发时启用，无需后端即可测试
VITE_USE_MOCK=true
