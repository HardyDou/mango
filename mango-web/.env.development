# Mango Web - Development Environment

# API Proxy Target (only 127.0.0.1 and localhost allowed for SSRF protection)
VITE_ADMIN_PROXY_PATH=http://127.0.0.1:9999

# Server
VITE_PORT=5173
VITE_OPEN=true

# SM4 Encryption Key (dev only, never use in production)
VITE_SM4_KEY=0123456789abcdef

# App
VITE_APP_TITLE=Mango Admin
