{
  "name": "mango-ui",
  "private": true,
  "description": "Mango UI - Micro Frontend Monorepo",
  "scripts": {
    "dev": "pnpm admin:styles && pnpm -F mango-admin dev",
    "dev:micro": "node ./scripts/dev-micro.mjs",
    "preview:micro": "node ./scripts/preview-micro.mjs",
    "build": "pnpm admin:styles && pnpm -r build",
    "build:micro": "pnpm admin:styles && pnpm -F mango-admin-shell build && pnpm -F mango-admin-rbac-app build && pnpm -F mango-admin-workflow-app build && pnpm -F mango-admin-template-app build",
    "admin:styles": "node ./scripts/generate-package-styles.mjs --root . --manifest ./packages/admin/admin-packages.json --package ./packages/admin/package.json --out ./packages/admin/generated-package-styles.css",
    "admin:styles:check": "node ./scripts/generate-package-styles.mjs --root . --manifest ./packages/admin/admin-packages.json --package ./packages/admin/package.json --out ./packages/admin/generated-package-styles.css --check",
    "test:micro": "node_modules/.pnpm/node_modules/.bin/playwright test --config apps/mango-admin-shell/playwright.config.ts",
    "lint": "pnpm -r lint",
    "publish:pkg": "node ./scripts/publish-package.mjs"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vite": "^5.1.4"
  }
}
