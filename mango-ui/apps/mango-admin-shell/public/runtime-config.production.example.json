{
  "profile": "hybrid",
  "modules": {
    "mango-authorization": {
      "mode": "micro",
      "runtimeCode": "mango-admin-rbac-app",
      "entry": "https://rbac.mango.io/",
      "timeoutMs": 15000,
      "preload": false,
      "alive": false
    },
    "mango-system": {
      "mode": "local",
      "runtimeCode": "mango-admin-system-local"
    },
    "mango-workflow": {
      "mode": "micro",
      "runtimeCode": "mango-admin-workflow-app",
      "entry": "https://workflow.mango.io/",
      "timeoutMs": 15000,
      "preload": true,
      "alive": false
    },
    "mango-template": {
      "mode": "micro",
      "runtimeCode": "mango-admin-template-app",
      "entry": "https://template.mango.io/",
      "timeoutMs": 15000,
      "preload": false,
      "alive": false
    }
  }
}
