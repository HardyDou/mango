{
  "name": "@mango/admin",
  "version": "1.0.33",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./full": {
      "types": "./dist/full.d.ts",
      "import": "./dist/full.js"
    },
    "./style.css": "./style.css",
    "./style-full.css": "./style-full.css"
  },
  "scripts": {
    "prepack": "pnpm run build",
    "build": "pnpm run build:style-deps && pnpm run generate:styles && vite build && node ../../scripts/generate-package-types.mjs",
    "build:style-deps": "node ./build-style-deps.mjs",
    "check:styles": "node ../../scripts/generate-package-styles.mjs --root ../.. --manifest ./packages/admin/admin-modules.json --package ./packages/admin/package.json --out ./packages/admin/generated-package-styles.css --admin-manifest-out ./packages/admin/admin-packages.json --full-style-out ./packages/admin/style-full.css --full-entry-out ./packages/admin/src/full.ts --full-types-out ./packages/admin/src/full.d.ts --build-deps-script-out ./packages/admin/build-style-deps.mjs --check",
    "generate:styles": "node ../../scripts/generate-package-styles.mjs --root ../.. --manifest ./packages/admin/admin-modules.json --package ./packages/admin/package.json --out ./packages/admin/generated-package-styles.css --admin-manifest-out ./packages/admin/admin-packages.json --full-style-out ./packages/admin/style-full.css --full-entry-out ./packages/admin/src/full.ts --full-types-out ./packages/admin/src/full.d.ts --build-deps-script-out ./packages/admin/build-style-deps.mjs"
  },
  "files": [
    "dist",
    "admin-modules.json",
    "admin-packages.json",
    "generated-package-styles.css",
    "style-full.css",
    "style.css",
    "README.md",
    "package.json"
  ],
  "dependencies": {
    "@element-plus/icons-vue": "2.3.2",
    "@mango/admin-pages": "1.0.12",
    "@mango/admin-shell": "1.0.29",
    "@mango/app-runtime": "1.0.2",
    "@mango/auth": "1.0.9",
    "@mango/cms": "1.0.2",
    "@mango/common": "1.0.11",
    "@mango/grid-layout": "1.0.2",
    "@mango/grid-widgets": "1.0.6",
    "@mango/job": "1.0.5",
    "@mango/rbac": "1.0.9",
    "@mango/system": "1.0.11",
    "element-plus": "2.14.1"
  },
  "peerDependencies": {
    "@mango/calendar": "1.0.13",
    "@mango/file": "1.0.13",
    "@mango/notice": "1.0.14",
    "@mango/numgen": "1.0.13",
    "@mango/payment": "1.0.4",
    "@mango/template": "1.0.13",
    "@mango/workflow": "1.0.17",
    "@mango/workflow-business-example": "1.0.16",
    "pinia": "2.0.32",
    "vue": "3.5.13",
    "vue-i18n": "9.2.2",
    "vue-router": "^4.1.6"
  },
  "peerDependenciesMeta": {
    "@mango/calendar": {
      "optional": true
    },
    "@mango/file": {
      "optional": true
    },
    "@mango/notice": {
      "optional": true
    },
    "@mango/numgen": {
      "optional": true
    },
    "@mango/payment": {
      "optional": true
    },
    "@mango/template": {
      "optional": true
    },
    "@mango/workflow": {
      "optional": true
    },
    "@mango/workflow-business-example": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^4.3.3"
  },
  "publishConfig": {
    "registry": "http://nexus.inner.yunxinbaokeji.com/repository/npm-hosted/"
  }
}
