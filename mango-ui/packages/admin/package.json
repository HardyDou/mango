{
  "name": "@mango/admin",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./style.css"
  },
  "scripts": {
    "build": "pnpm run check:styles && vite build",
    "check:styles": "node ../../scripts/generate-package-styles.mjs --root ../.. --manifest ./packages/admin/admin-packages.json --package ./packages/admin/package.json --out ./packages/admin/generated-package-styles.css --check",
    "generate:styles": "node ../../scripts/generate-package-styles.mjs --root ../.. --manifest ./packages/admin/admin-packages.json --package ./packages/admin/package.json --out ./packages/admin/generated-package-styles.css"
  },
  "files": [
    "dist",
    "src/index.d.ts",
    "admin-packages.json",
    "generated-package-styles.css",
    "style.css",
    "package.json"
  ],
  "dependencies": {
    "@element-plus/icons-vue": "^2.0.10",
    "@mango/admin-pages": "1.0.0",
    "@mango/admin-shell": "1.0.0",
    "@mango/app-runtime": "1.0.0",
    "@mango/auth": "1.0.0",
    "@mango/calendar": "1.0.0",
    "@mango/common": "1.0.0",
    "@mango/file": "1.0.0",
    "@mango/notice": "1.0.0",
    "@mango/numgen": "1.0.0",
    "@mango/rbac": "1.0.0",
    "@mango/system": "1.0.0",
    "@mango/template": "1.0.0",
    "@mango/workflow": "1.0.0",
    "@mango/workflow-business-example": "1.0.0",
    "element-plus": "2.5.5"
  },
  "peerDependencies": {
    "pinia": "2.0.32",
    "vue": "3.5.13",
    "vue-i18n": "9.2.2",
    "vue-router": "^4.1.6"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^4.3.3"
  },
  "publishConfig": {
    "registry": "http://nexus.inner.yunxinbaokeji.com/repository/npm-hosted/"
  }
}
