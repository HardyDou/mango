{
  "name": "@mango/workflow",
  "version": "1.0.19",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "mangoAdmin": {
    "businessDomainCode": "WORKFLOW",
    "businessDomainName": "工作流",
    "groupName": "工作流",
    "style": "@mango/workflow/style.css",
    "registrars": [
      {
        "name": "registerMangoWorkflowAdminPages",
        "import": "@mango/workflow/admin-pages"
      }
    ]
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./admin-pages": {
      "types": "./dist/admin-pages.d.ts",
      "import": "./dist/admin-pages.js"
    },
    "./widgets/my-process": {
      "types": "./dist/widgets/my-process.d.ts",
      "import": "./dist/widgets/my-process.js"
    },
    "./widgets/my-task": {
      "types": "./dist/widgets/my-task.d.ts",
      "import": "./dist/widgets/my-task.js"
    },
    "./widgets/my-todo": {
      "types": "./dist/widgets/my-todo.d.ts",
      "import": "./dist/widgets/my-todo.js"
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "build": "vite build && node ../../scripts/generate-package-types.mjs",
    "test": "vitest run --config vitest.config.ts"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "dependencies": {
    "@element-plus/icons-vue": "2.3.2",
    "@form-create/element-ui": "3.2.42",
    "@mango/admin-pages": "1.0.13",
    "@mango/api-schema": "1.0.2",
    "@mango/common": "1.0.11",
    "@mango/file": "1.0.14",
    "@mango/grid-widgets": "1.0.8",
    "@mango/system": "1.0.12",
    "form-create-designer": "3.2.11-oem"
  },
  "peerDependencies": {
    "element-plus": "2.14.1",
    "vue": "3.5.13",
    "vue-router": "^4.1.6"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.0.0",
    "happy-dom": "^14.12.0",
    "typescript": "^5.9.3",
    "vite": "^4.3.3",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "registry": "http://nexus.inner.yunxinbaokeji.com/repository/npm-hosted/"
  },
  "types": "./dist/index.d.ts"
