{
  "version": 1,
  "groups": {
    "default": [
      "mango-backend",
      "mango-admin"
    ],
    "backend": [
      "mango-backend"
    ],
    "frontend": [
      "mango-admin"
    ]
  },
  "apps": {
    "mango-backend": {
      "type": "spring-boot-maven",
      "cwd": "mango",
      "pom": "mango-app/monolith/mango-monolith-app/pom.xml",
      "install": {
        "command": "mvn",
        "args": [
          "-f",
          "pom.xml",
          "-DskipTests",
          "install"
        ]
      },
      "goal": "org.springframework.boot:spring-boot-maven-plugin:3.5.14:run",
      "portEnv": "MANGO_BACKEND_PORT",
      "port": 18080,
      "health": "/actuator/health",
      "args": [
        "--server.port=${port}",
        "--spring.datasource.url=jdbc:mysql://${env.MANGO_DB_HOST}:${env.MANGO_DB_PORT}/${env.MANGO_DB_NAME}?useUnicode=true&characterEncoding=utf8&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai",
        "--spring.datasource.username=${env.MANGO_DB_USERNAME}",
        "--spring.datasource.password=${env.MANGO_DB_PASSWORD}",
        "--office.plugin.enabled=${env.MANGO_OFFICE_PLUGIN_ENABLED}",
        "${env.MANGO_BACKEND_ADDITIONAL_ARGS}"
      ]
    },
    "mango-admin": {
      "type": "vite",
      "cwd": "mango-ui",
      "dependsOn": [
        "mango-backend"
      ],
      "packageManager": "pnpm",
      "portEnv": "MANGO_FRONTEND_PORT",
      "port": 7770,
      "hostEnv": "MANGO_FRONTEND_HOST",
      "host": "127.0.0.1",
      "env": {
        "MANGO_FRONTEND_MODE": "${env.MANGO_FRONTEND_MODE}",
        "VITE_ADMIN_PROXY_PATH": "http://127.0.0.1:${apps.mango-backend.port}",
        "VITE_PORT": "${port}",
        "VITE_HOST": "${host}",
        "VITE_OPEN": "${env.MANGO_FRONTEND_OPEN}"
      },
      "args": [
        "-F",
        "mango-admin",
        "exec",
        "vite",
        "--force",
        "--host",
        "${host}",
        "--port",
        "${port}"
      ]
    }
  }
}
