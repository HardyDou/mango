#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
[[ -n "${repo_root}" ]] || exit 0

script="${repo_root}/scripts/dev-workspace.sh"
[[ -f "${script}" ]] || exit 0

bash "${script}" init >/dev/null || {
  echo "Mango workspace init failed. Run: ${script} init" >&2
  exit 1
}
