<?xml version="1.0" encoding="UTF-8"?>
<ruleset name="Mango Project PMD Rules"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.sourceforge.io/ruleset_2_0_0.xsd">

    <description>
        Mango 项目特有自动化检查规则集。
    </description>

    <!-- 1. 拦截异常处理规范 (C3) -->
    <!-- 引用 P3C 内置的异常规则 -->
    <rule ref="rulesets/java/ali-exception.xml"/>

    <!-- 2. Naming 强制规则 -->
    <!-- 实体类必须以 Entity 结尾 -->
    <rule name="MangoEntitySuffix"
          language="java"
          message="Mango 规约: 数据库实体类必须以 Entity 结尾（如 UserEntity），禁止使用 PO/DO。"
          class="net.sourceforge.pmd.lang.rule.xpath.XPathRule">
        <priority>3</priority>
        <properties>
            <property name="xpath">
                <value>
                    //ClassOrInterfaceDeclaration[
                        @Interface='false' and 
                        (matches(@Image, '.*PO$') or matches(@Image, '.*DO$'))
                    ]
                </value>
            </property>
        </properties>
    </rule>

    <!-- API 接口后缀 -->
    <rule name="MangoApiSuffix"
          language="java"
          message="Mango 规约: 暴露型 API 接口必须以 Api 结尾（如 AuthApi）。"
          class="net.sourceforge.pmd.lang.rule.xpath.XPathRule">
        <priority>3</priority>
        <properties>
            <property name="xpath">
                <value>
                    //ClassOrInterfaceDeclaration[
                        @Interface='true' and 
                        matches(@Image, '.*Client$')
                    ]
                </value>
            </property>
        </properties>
    </rule>

    <!-- 3. P3C 基础规则 -->
    <rule ref="rulesets/java/ali-set.xml"/>
    <rule ref="rulesets/java/ali-concurrent.xml"/>
    <rule ref="rulesets/java/ali-flowcontrol.xml"/>

</ruleset>
