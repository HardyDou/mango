<?xml version="1.0" encoding="UTF-8"?>
<ruleset name="Mango Project PMD Rules"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.sourceforge.io/ruleset_2_0_0.xsd">

    <description>
        Mango 项目特有自动化检查规则集。
        该规则集只包含明确、不主观且泛化能力强的规则（如强制使用特性包、禁止生吞异常等）。
        不再包含方法长度和代码重复度等依赖上下文和主观判断的规则（交由Review决定）。
    </description>

    <!-- 1. 拦截直接捕获 Throwable / Exception (异常处理规范 C3.1) -->
    <rule ref="category/java/errorprone.xml/AvoidCatchingThrowable" message="禁止捕获 Throwable, 请捕获具体的业务异常。">
        <priority>2</priority>
    </rule>
    <rule ref="category/java/errorprone.xml/AvoidCatchingGenericException" message="尽量避免捕获通用的 Exception, 应捕获精确的异常类型。">
        <priority>3</priority>
    </rule>

    <!-- 2. 禁止生吞异常 (异常处理规范 C3.3) -->
    <rule ref="category/java/errorprone.xml/EmptyCatchBlock" message="禁止生吞异常，catch 块中必须有日志记录或异常包装。">
        <priority>1</priority>
    </rule>

    <!-- 3. 禁止使用 System.out/err 打印日志 -->
    <rule ref="category/java/errorprone.xml/SystemPrintln" message="业务代码中禁止使用 System.out/err，请使用 LoggerFactory 输出日志。">
        <priority>2</priority>
    </rule>
    
    <!-- 4. P3C 基础规则引用（仅引用不冲突的强规则模块） -->
    <!-- 集合规范: 不涉及长度和代码复用，全是防坑死角 -->
    <rule ref="rulesets/java/ali-set.xml"/>
    <!-- 并发规范: 拦截线程池未重用、ThreadLocal 泄漏等 -->
    <rule ref="rulesets/java/ali-concurrent.xml"/>
    <!-- 流程控制: 防止空指针、死循环等明确错误 -->
    <rule ref="rulesets/java/ali-flowcontrol.xml"/>

</ruleset>
