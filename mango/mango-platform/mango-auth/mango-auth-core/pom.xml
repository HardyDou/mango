<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>io.mango.platform.auth</groupId>
        <artifactId>mango-auth</artifactId>
        <version>${revision}</version>
    </parent>

    <artifactId>mango-auth-core</artifactId>
    <packaging>jar</packaging>

    <name>Mango Auth Core</name>
    <description>Mango Auth Module - Business implementation</description>

    <dependencies>
        <!-- Mango 认证 API 契约 -->
        <dependency>
            <groupId>io.mango.platform.auth</groupId>
            <artifactId>mango-auth-api</artifactId>
            <version>${project.version}</version>
        </dependency>

        <dependency>
            <groupId>io.mango.platform.authorization</groupId>
            <artifactId>mango-authorization-api</artifactId>
            <version>${project.version}</version>
        </dependency>

        <dependency>
            <groupId>io.mango.platform.identity</groupId>
            <artifactId>mango-identity-api</artifactId>
            <version>${project.version}</version>
        </dependency>

        <dependency>
            <groupId>io.mango.platform.notice</groupId>
            <artifactId>mango-notice-api</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Mango 通用能力 -->
        <dependency>
            <groupId>io.mango.common</groupId>
            <artifactId>mango-common</artifactId>
        </dependency>

        <!-- Spring Security Crypto，用于 BCrypt 密码编码 -->
        <dependency>
            <groupId>org.springframework.security</groupId>
            <artifactId>spring-security-crypto</artifactId>
        </dependency>

        <dependency>
            <groupId>org.bouncycastle</groupId>
            <artifactId>bcprov-jdk18on</artifactId>
        </dependency>
        <dependency>
            <groupId>org.bouncycastle</groupId>
            <artifactId>bcpkix-jdk18on</artifactId>
        </dependency>

        <!-- Spring Context，用于服务和配置注解 -->
        <dependency>
            <groupId>org.springframework</groupId>
            <artifactId>spring-context</artifactId>
        </dependency>

        <!-- Lombok @Slf4j 使用的日志 API -->
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-api</artifactId>
        </dependency>

        <!-- Mango KV 存储 API，用于安全防护服务 -->
        <dependency>
            <groupId>io.mango.infra.kv</groupId>
            <artifactId>mango-infra-kv-api</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Mango 基础上下文能力，用于登录期按租户加载授权快照 -->
        <dependency>
            <groupId>io.mango.infra.context</groupId>
            <artifactId>mango-infra-context-api</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Lombok -->
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <scope>provided</scope>
        </dependency>

        <!-- 测试依赖 -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

</project>
