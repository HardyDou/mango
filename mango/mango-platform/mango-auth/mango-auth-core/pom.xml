<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>io.mango</groupId>
        <artifactId>mango-auth</artifactId>
        <version>1.0.0-SNAPSHOT</version>
    </parent>

    <artifactId>mango-auth-core</artifactId>
    <packaging>jar</packaging>

    <name>Mango Auth Core</name>
    <description>Mango Auth Module - Business implementation</description>

    <dependencies>
        <!-- Mango Auth API -->
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-auth-api</artifactId>
            <version>${project.version}</version>
        </dependency>

        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-authorization-api</artifactId>
            <version>${project.version}</version>
        </dependency>

        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-identity-api</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- MyBatis-Plus -->
        <dependency>
            <groupId>com.baomidou</groupId>
            <artifactId>mybatis-plus-boot-starter</artifactId>
        </dependency>

        <!-- Mango Common -->
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-common</artifactId>
        </dependency>

        <!-- Mango Infra Security API (ITokenService) -->
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-infra-security-api</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Spring Security Crypto (for BCrypt password encoding) -->
        <dependency>
            <groupId>org.springframework.security</groupId>
            <artifactId>spring-security-crypto</artifactId>
        </dependency>

        <dependency>
            <groupId>org.bouncycastle</groupId>
            <artifactId>bcprov-jdk18on</artifactId>
        </dependency>
        <dependency>
            <groupId>org.bouncycastle</groupId>
            <artifactId>bcpkix-jdk18on</artifactId>
        </dependency>

        <!-- Spring Boot Web (for WebMvcConfigurer) -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>

        <!-- Mango KV Store API (for AntiService) -->
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-infra-kv-api</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Mango Captcha API (for CaptchaInterceptor) -->
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-captcha-api</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Lombok -->
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <scope>provided</scope>
        </dependency>

        <!-- Test -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

</project>
