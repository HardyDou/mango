<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>io.mango.platform.auth</groupId>
        <artifactId>mango-auth</artifactId>
        <version>${revision}</version>
    </parent>

    <artifactId>mango-auth-starter</artifactId>
    <packaging>jar</packaging>

    <name>Mango Auth Starter</name>
    <description>Auth service starter for local usage</description>

    <dependencies>
        <!-- Mango 认证核心实现 -->
        <dependency>
            <groupId>io.mango.platform.auth</groupId>
            <artifactId>mango-auth-core</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Mango 基础 Web Starter，提供 Spring Web 与请求上下文 -->
        <dependency>
            <groupId>io.mango.infra.web</groupId>
            <artifactId>mango-infra-web-starter</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Mango 通用能力 -->
        <dependency>
            <groupId>io.mango.common</groupId>
            <artifactId>mango-common</artifactId>
        </dependency>

        <!-- Spring Security Crypto，用于 BCryptPasswordEncoder Bean -->
        <dependency>
            <groupId>org.springframework.security</groupId>
            <artifactId>spring-security-crypto</artifactId>
        </dependency>

        <!-- Mango 基础上下文，用于异步登录上下文传递 -->
        <dependency>
            <groupId>io.mango.infra.context</groupId>
            <artifactId>mango-infra-context-starter</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Mango KV 存储 API，用于分布式登录失败追踪 -->
        <dependency>
            <groupId>io.mango.infra.kv</groupId>
            <artifactId>mango-infra-kv-api</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Mango IP 归属地解析 API，用于登录审计日志 -->
        <dependency>
            <groupId>io.mango.infra.ip.location</groupId>
            <artifactId>mango-infra-ip-location-api</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Mango 验证码 API，用于 CaptchaInterceptor -->
        <dependency>
            <groupId>io.mango.platform.captcha</groupId>
            <artifactId>mango-captcha-api</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Mango 授权 Starter -->
        <dependency>
            <groupId>io.mango.platform.authorization</groupId>
            <artifactId>mango-authorization-starter</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Mango 边界访问配置，用于复用 IP 白名单规则 -->
        <dependency>
            <groupId>io.mango.platform.access</groupId>
            <artifactId>mango-access-core</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Mango 系统 API，用于可选记录登录审计日志 -->
        <dependency>
            <groupId>io.mango.platform.system</groupId>
            <artifactId>mango-system-api</artifactId>
            <version>${project.version}</version>
        </dependency>
        <!-- OpenAPI 注解仅用于 controller 文档展示 -->
        <dependency>
            <groupId>io.swagger.core.v3</groupId>
            <artifactId>swagger-annotations</artifactId>
        </dependency>

        <!-- Servlet API，用于 Filter -->
        <dependency>
            <groupId>jakarta.servlet</groupId>
            <artifactId>jakarta.servlet-api</artifactId>
            <scope>provided</scope>
        </dependency>

        <!-- Lombok -->
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <scope>provided</scope>
        </dependency>

        <!-- 测试依赖 -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.springframework.security</groupId>
            <artifactId>spring-security-test</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

</project>
