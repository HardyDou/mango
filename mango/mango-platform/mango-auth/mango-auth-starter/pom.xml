<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>io.mango</groupId>
        <artifactId>mango-auth</artifactId>
        <version>1.0.0-SNAPSHOT</version>
    </parent>

    <artifactId>mango-auth-starter</artifactId>
    <packaging>jar</packaging>

    <name>Mango Auth Starter</name>
    <description>Auth service starter for local usage</description>

    <dependencies>
        <!-- Mango 认证核心实现 -->
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-auth-core</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Mango 基础 Web Starter，提供 Spring Web 与请求上下文 -->
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-infra-web-starter</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Mango 通用能力 -->
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-common</artifactId>
        </dependency>

        <!-- Spring Security Crypto，用于 BCryptPasswordEncoder Bean -->
        <dependency>
            <groupId>org.springframework.security</groupId>
            <artifactId>spring-security-crypto</artifactId>
        </dependency>

        <!-- Mango 基础安全，自动配置 ITokenProvider 实现 -->
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-infra-security-starter</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Mango 基础上下文，用于异步登录上下文传递 -->
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-infra-context-starter</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Mango KV 存储 API，用于分布式登录失败追踪 -->
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-infra-kv-api</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Mango 验证码 API，用于 CaptchaInterceptor -->
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-captcha-api</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Mango 授权 Starter -->
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-authorization-starter</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Servlet API，用于 Filter -->
        <dependency>
            <groupId>jakarta.servlet</groupId>
            <artifactId>jakarta.servlet-api</artifactId>
            <scope>provided</scope>
        </dependency>

        <!-- Lombok -->
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <scope>provided</scope>
        </dependency>

        <!-- 测试依赖 -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.springframework.security</groupId>
            <artifactId>spring-security-test</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

</project>
