{
  "name": "Mango Quality Gate",
  "description": "Mango 脚手架项目质量门禁标准",
  "isBuiltIn": false,
  "isDefault": true,
  "conditions": [
    {
      "metric": "new_reliability_rating",
      "operator": "GREATER_THAN",
      "value": "1",
      "description": "可靠性评级 ≥ B"
    },
    {
      "metric": "new_security_rating",
      "operator": "GREATER_THAN",
      "value": "1",
      "description": "安全性评级 ≥ B"
    },
    {
      "metric": "new_maintainability_rating",
      "operator": "GREATER_THAN",
      "value": "1",
      "description": "可维护性评级 ≥ B"
    },
    {
      "metric": "new_coverage",
      "operator": "LESS_THAN",
      "value": "0.6",
      "description": "测试覆盖率 ≥ 60%"
    },
    {
      "metric": "new_duplicated_lines_density",
      "operator": "GREATER_THAN",
      "value": "3",
      "description": "重复率 ≤ 3%"
    },
    {
      "metric": "new_blocker_violations",
      "operator": "EQUALS",
      "value": "0",
      "description": "无阻断级问题"
    },
    {
      "metric": "new_critical_violations",
      "operator": "EQUALS",
      "value": "0",
      "description": "无严重级问题"
    }
  ]
}
