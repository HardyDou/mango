<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>io.mango</groupId>
        <artifactId>mango-infra</artifactId>
        <version>1.0.0-SNAPSHOT</version>
    </parent>

    <artifactId>mango-infra-test</artifactId>
    <packaging>jar</packaging>

    <name>Mango Infra Test</name>
    <description>Mango Infra Test - Unified test module for all infrastructure components</description>

    <dependencies>
        <!-- Spring Boot Test -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- Spring Boot Web (for Filter/Web testing) -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-webflux</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- AssertJ -->
        <dependency>
            <groupId>org.assertj</groupId>
            <artifactId>assertj-core</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- Lombok -->
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <scope>provided</scope>
        </dependency>

        <!-- Mango Common -->
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-common</artifactId>
        </dependency>

        <!-- Mango Infra Log (for testing Log integration) -->
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-infra-log-starter</artifactId>
        </dependency>

        <!-- Mango Infra KV (for testing KV components) -->
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-infra-kv-api</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-infra-kv-core</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-infra-kv-starter</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-infra-redis-starter</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-infra-persistence-starter</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Mango Infra Realtime (for testing realtime components) -->
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-infra-realtime-api</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-infra-realtime-core</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-infra-realtime-starter</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-infra-realtime-starter-remote</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>org.springframework.cloud</groupId>
            <artifactId>spring-cloud-starter-loadbalancer</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- Test containers -->
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers</artifactId>
            <version>1.20.0</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>junit-jupiter</artifactId>
            <version>1.20.0</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

</project>
