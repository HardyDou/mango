<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>io.mango.app.monolith</groupId>
        <artifactId>mango-app-monolith</artifactId>
        <version>1.0.0-SNAPSHOT</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <artifactId>mango-monolith-app</artifactId>
    <packaging>jar</packaging>

    <name>Mango Monolith App</name>
    <description>Mango 单体部署应用，在一个进程内装配平台与业务能力</description>

    <dependencies>
        <dependency>
            <groupId>io.mango.common</groupId>
            <artifactId>mango-common</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.infra.module</groupId>
            <artifactId>mango-infra-module-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.infra.kv</groupId>
            <artifactId>mango-infra-kv-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.infra.event</groupId>
            <artifactId>mango-infra-event-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.infra.ip.location</groupId>
            <artifactId>mango-infra-ip-location-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.infra.realtime</groupId>
            <artifactId>mango-infra-realtime-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.infra.persistence</groupId>
            <artifactId>mango-infra-persistence-web-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.infra.doc</groupId>
            <artifactId>mango-infra-doc-starter</artifactId>
        </dependency>

        <dependency>
            <groupId>io.mango.platform.auth</groupId>
            <artifactId>mango-auth-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.platform.identity</groupId>
            <artifactId>mango-identity-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.platform.authorization</groupId>
            <artifactId>mango-authorization-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.platform.authorization</groupId>
            <artifactId>mango-authorization-resource-sync-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.platform.authorization</groupId>
            <artifactId>mango-authorization-resource-access-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.platform.access</groupId>
            <artifactId>mango-access-web-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.platform.org</groupId>
            <artifactId>mango-org-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.platform.captcha</groupId>
            <artifactId>mango-captcha-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.platform.system</groupId>
            <artifactId>mango-system-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.platform.biz.notification</groupId>
            <artifactId>mango-biz-notification-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.platform.file</groupId>
            <artifactId>mango-file-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.platform.file.preview</groupId>
            <artifactId>mango-file-preview-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.platform.template</groupId>
            <artifactId>mango-template-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.platform.workflow</groupId>
            <artifactId>mango-workflow-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.platform.calendar</groupId>
            <artifactId>mango-calendar-starter</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>io.mango.platform.numgen</groupId>
            <artifactId>mango-numgen-starter</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>io.mango.infra.web</groupId>
            <artifactId>mango-infra-web-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-actuator</artifactId>
        </dependency>
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <scope>provided</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <version>${spring-boot.version}</version>
                <configuration>
                    <skip>false</skip>
                    <mainClass>io.mango.app.monolith.MangoMonolithApplication</mainClass>
                </configuration>
                <executions>
                    <execution>
                        <goals>
                            <goal>repackage</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
