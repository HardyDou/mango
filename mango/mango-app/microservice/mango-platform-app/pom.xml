<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>io.mango</groupId>
        <artifactId>mango-app-microservice</artifactId>
        <version>1.0.0-SNAPSHOT</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <artifactId>mango-platform-app</artifactId>
    <packaging>jar</packaging>

    <name>Mango Platform App</name>
    <description>微服务拓扑下的平台支撑能力部署入口</description>

    <dependencies>
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-common</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-infra-module-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-infra-kv-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-infra-realtime-starter</artifactId>
        </dependency>

        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-security-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-org-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-area-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-ai-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-i18n-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-captcha-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-system-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango</groupId>
            <artifactId>mango-biz-notification-starter</artifactId>
        </dependency>

        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-actuator</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springdoc</groupId>
            <artifactId>springdoc-openapi-starter-webmvc-ui</artifactId>
            <version>2.3.0</version>
        </dependency>
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <scope>provided</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <version>${spring-boot.version}</version>
                <executions>
                    <execution>
                        <goals>
                            <goal>repackage</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
