<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>io.mango.app.microservice</groupId>
        <artifactId>mango-app-microservice</artifactId>
        <version>1.0.0-SNAPSHOT</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <artifactId>mango-platform-app</artifactId>
    <packaging>jar</packaging>

    <name>Mango Platform App</name>
    <description>微服务拓扑下的平台支撑能力部署入口</description>

    <dependencies>
        <dependency>
            <groupId>io.mango.common</groupId>
            <artifactId>mango-common</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.infra.module</groupId>
            <artifactId>mango-infra-module-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.infra.kv</groupId>
            <artifactId>mango-infra-kv-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.infra.event</groupId>
            <artifactId>mango-infra-event-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.infra.realtime</groupId>
            <artifactId>mango-infra-realtime-starter</artifactId>
        </dependency>

        <dependency>
            <groupId>io.mango.platform.auth</groupId>
            <artifactId>mango-auth-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.platform.identity</groupId>
            <artifactId>mango-identity-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.platform.authorization</groupId>
            <artifactId>mango-authorization-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.platform.authorization</groupId>
            <artifactId>mango-authorization-resource-sync-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.platform.authorization</groupId>
            <artifactId>mango-authorization-resource-access-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.platform.org</groupId>
            <artifactId>mango-org-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.platform.captcha</groupId>
            <artifactId>mango-captcha-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.platform.system</groupId>
            <artifactId>mango-system-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.platform.domain</groupId>
            <artifactId>mango-domain-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.platform.notice</groupId>
            <artifactId>mango-notice-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.platform.workflow</groupId>
            <artifactId>mango-workflow-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.platform.job</groupId>
            <artifactId>mango-job-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.platform.file</groupId>
            <artifactId>mango-file-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.platform.file.preview</groupId>
            <artifactId>mango-file-preview-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>io.mango.platform.template</groupId>
            <artifactId>mango-template-starter</artifactId>
        </dependency>

        <dependency>
            <groupId>io.mango.infra.web</groupId>
            <artifactId>mango-infra-web-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-actuator</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springdoc</groupId>
            <artifactId>springdoc-openapi-starter-webmvc-ui</artifactId>
        </dependency>
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <scope>provided</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <version>${spring-boot.version}</version>
                <configuration>
                    <skip>false</skip>
                    <mainClass>io.mango.app.microservice.platform.MangoPlatformAppApplication</mainClass>
                </configuration>
                <executions>
                    <execution>
                        <goals>
                            <goal>repackage</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
