<?xml version="1.0" encoding="UTF-8"?>
<!-- SpotBugs 安全规则过滤器 -->
<FindBugsFilter>
    <!-- 高危安全检测 -->
    <Match>
        <Bug category="SECURITY"/>
    </Match>
    <!-- SQL 注入 -->
    <Match>
        <Bug pattern="SQL_INJECTION"/>
    </Match>
    <!-- 命令注入 -->
    <Match>
        <Bug pattern="COMMAND_INJECTION"/>
    </Match>
    <!-- 硬编码密码 -->
    <Match>
        <Bug pattern="HARD_CODE_PASSWORD"/>
    </Match>
    <!-- 硬编码密钥 -->
    <Match>
        <Bug pattern="HARD_CODE_CREDENTIALS"/>
    </Match>
    <!-- XSS -->
    <Match>
        <Bug pattern="XSS_REQUEST_WRAPPER"/>
    </Match>
    <!-- Path Traversal -->
    <Match>
        <Bug pattern="PATH_TRAVERSAL"/>
    </Match>
</FindBugsFilter>
